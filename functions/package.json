    "engines": {
        "node": ">=22"
    },
    "main": "lib/index.js",
    "dependencies": {
        "firebase-admin": "^13.7.0",
        "firebase-functions": "^7.2.3"
    },
    "devDependencies": {
        "typescript": "^6.0.2"
    },
    "overrides": {
        "@tootallnate/once": "^3.0.1"
    },
    "private": true
}
